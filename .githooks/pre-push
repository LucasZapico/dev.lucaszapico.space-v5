#!/usr/bin/env bash
# Pre-push hook:
#   1. Block commits containing non-webp images (PNG, JPG, JPEG)
#   2. Ensure audio narration is in sync with builds.ts + case-studies.ts
#
# Bypass once with `git push --no-verify` if you really need to.

set -e

# ---------------------------------------------------------------------------
# 1. Non-webp image block
# ---------------------------------------------------------------------------
BLOCKED_EXTENSIONS="png|jpg|jpeg"
BLOCKED_FILES=$(git diff --cached --name-only --diff-filter=ACM HEAD 2>/dev/null | grep -iE "\.($BLOCKED_EXTENSIONS)$" || true)

if [ -z "$BLOCKED_FILES" ]; then
  BLOCKED_FILES=$(git diff --name-only HEAD @{push} 2>/dev/null | grep -iE "\.($BLOCKED_EXTENSIONS)$" || true)
fi

if [ -n "$BLOCKED_FILES" ]; then
  echo ""
  echo "ERROR: Non-webp images found in commits being pushed:"
  echo ""
  echo "$BLOCKED_FILES" | sed 's/^/  /'
  echo ""
  echo "Convert to webp first:"
  echo "  cwebp -q 85 input.png -o output.webp"
  echo ""
  exit 1
fi

# ---------------------------------------------------------------------------
# 2. Audio narration drift check
# ---------------------------------------------------------------------------
if [ -z "${SKIP_AUDIO_CHECK:-}" ]; then
  if ! pnpm audio:check; then
    cat <<'MSG'

Push aborted: audio is out of sync with builds.ts / case-studies.ts.

  Regenerate:   pnpm audio
  Then commit:  git add public/audio && git commit
  Bypass once:  git push --no-verify

MSG
    exit 1
  fi
fi

exit 0
